{
	"name": "users",
	"main": "dist/index.js",
	"homepage": "https://sdlmdev.github.io/Users/",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22.11.0",
		"npm": ">=10.9.0"
	},
	"scripts": {
		"server": "node --watch server/index.js",
		"dev": "concurrently \"npm run vite\" \"npm run server\"",
		"vite": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "eslint . --max-warnings 0",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"stylelint": "stylelint \"src/**/*.{scss,css}\"",
		"stylelint:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
		"prepare": "husky",
		"predeploy": "tsc -b && npx cross-env VITE_APP_GH_PAGES=true vite build",
		"db:gen": "node scripts/db-gen.js 1000",
		"deploy": "gh-pages -d dist"
	},
	"dependencies": {
		"classnames": "^2.5.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-router-dom": "^7.13.2",
		"react-virtuoso": "^4.18.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.0",
		"@commitlint/config-conventional": "^19.8.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.23.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/react": "^19.0.10",
		"@types/react-dom": "^19.0.4",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^3.0.9",
		"babel-plugin-react-compiler": "^1.0.0",
		"commitlint": "^19.8.0",
		"concurrently": "^9.2.1",
		"eslint": "^9.23.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.4",
		"eslint-plugin-react-compiler": "^19.1.0-rc.2",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"eslint-plugin-unused-imports": "^4.4.1",
		"gh-pages": "^6.3.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"json-server": "^0.17.4",
		"lint-staged": "^15.5.0",
		"lucide-react": "^1.7.0",
		"prettier": "^3.5.3",
		"sass": "^1.86.0",
		"stylelint": "^16.17.0",
		"stylelint-config-clean-order": "^8.0.1",
		"stylelint-config-standard-scss": "^14.0.0",
		"stylelint-no-unsupported-browser-features": "^8.1.1",
		"stylelint-order": "^8.1.1",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.28.0",
		"vite": "^6.2.3"
	}
}
